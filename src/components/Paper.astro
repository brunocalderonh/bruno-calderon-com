---
interface Props {
  title: string;
  venue: string;
  year: string;
  authors: string;
  url: string;
  doi?: string;
  abstract?: string;
  note?: string;
}

const { title, venue, year, authors, url, doi, abstract, note } = Astro.props;
---

<article class="group py-6 border-b border-[var(--color-rule)] dark:border-[var(--color-rule-dark)] last:border-b-0">
  <div class="flex items-baseline gap-3 text-xs uppercase tracking-wider text-[var(--color-ink-soft)] dark:text-[var(--color-ink-soft-dark)] mb-2">
    <span>{year}</span>
    <span class="font-medium">{venue}</span>
  </div>
  <h3 class="font-serif text-xl md:text-2xl leading-snug mb-2">
    <a href={url} target="_blank" rel="noopener" class="!text-[var(--color-ink)] dark:!text-[var(--color-ink-dark)] hover:!text-[var(--color-accent)] dark:hover:!text-[var(--color-accent-dark)]">
      {title}
    </a>
  </h3>
  <p class="text-sm text-[var(--color-ink-soft)] dark:text-[var(--color-ink-soft-dark)] leading-snug">
    {authors}
  </p>
  {note && (
    <p class="mt-2 text-sm italic text-[var(--color-ink-soft)] dark:text-[var(--color-ink-soft-dark)]">
      {note}
    </p>
  )}
  {abstract && (
    <details class="mt-3 group/abs">
      <summary class="cursor-pointer text-sm text-[var(--color-accent)] dark:text-[var(--color-accent-dark)] hover:opacity-80 select-none list-none">
        <span class="group-open/abs:hidden">Show abstract</span>
        <span class="hidden group-open/abs:inline">Hide abstract</span>
      </summary>
      <p class="mt-3 text-sm text-[var(--color-ink-soft)] dark:text-[var(--color-ink-soft-dark)] leading-relaxed">
        {abstract}
      </p>
    </details>
  )}
  <div class="mt-3 flex flex-wrap gap-x-4 gap-y-1 text-xs">
    <a href={url} target="_blank" rel="noopener">Read →</a>
    {doi && (
      <a href={`https://doi.org/${doi}`} target="_blank" rel="noopener" class="text-[var(--color-ink-soft)] dark:text-[var(--color-ink-soft-dark)]">
        doi:{doi}
      </a>
    )}
  </div>
</article>
